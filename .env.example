# ==========================================
# AI-Powered Placement Assistant
# Environment Configuration Template
# ==========================================

# Environment: development, staging, production
ENVIRONMENT=development

# ==========================================
# Backend Configuration
# ==========================================

# JWT Secret Key (must be changed in production)
# Generate with: openssl rand -hex 32
SECRET_KEY=your_secret_key_here_minimum_32_characters_required

# Database URL
# Development: SQLite
# Production: PostgreSQL
DATABASE_URL=sqlite:///./placement_assistant.db
# DATABASE_URL=postgresql://user:password@localhost:5432/placement_db

# PostgreSQL Configuration (for production)
POSTGRES_USER=placement_user
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=placement_db

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8501,http://localhost:8000

# ==========================================
# Caching Configuration
# ==========================================

# Redis Cache URL
REDIS_URL=redis://localhost:6379/0
# For production with password: redis://:password@host:port/db
REDIS_PASSWORD=redis_password_change_me

# Enable caching (true/false)
ENABLE_CACHE=true

# Cache TTL in seconds (default: 1 hour)
CACHE_TTL_SECONDS=3600

# ==========================================
# AI Configuration
# ==========================================

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your_gemini_api_key_here

# Chroma DB Directory
CHROMA_DB_DIR=./chroma_db

# ==========================================
# Frontend Configuration
# ==========================================

# Backend API URL (as seen by frontend)
BACKEND_API_URL=http://localhost:8000/api

# ==========================================
# Deployment Configuration
# ==========================================

# For Render deployment
# BACKEND_API_URL=https://your-backend.onrender.com/api

# For AWS deployment
# DATABASE_URL=postgresql://user:pass@rds-endpoint.amazonaws.com:5432/db
# REDIS_URL=redis://:password@elasticache-endpoint.amazonaws.com:6379/0
# CHROMA_DB_DIR=/app/chroma_db (use persistent disk mount)
